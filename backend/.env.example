# RipReport backend — every key is optional. With none set, the service runs
# fully on mock data in the live shape.

PORT=8787

# 'mock' (default) or 'live'. Live mode fetches the real catalog on boot and
# switches pricing to cached-comp reads (modelled fallback until comps exist).
DATA_MODE=mock

# --- Feed 1: catalog ---------------------------------------------------------
# Free key from https://dev.pokemontcg.io — optional; keyless works with lower
# rate limits.
POKEMONTCG_API_KEY=
# How many of the latest sets to ingest on boot.
CATALOG_SET_LIMIT=8

# --- Postgres (catalog + price cache persistence) ----------------------------
# e.g. postgres://user:pass@host:5432/ripreport  (Supabase/Neon/Railway).
# Unset = in-memory store (resets on restart).
DATABASE_URL=

# --- Feed 2: pricing ---------------------------------------------------------
# https://www.pricecharting.com/api-documentation
PRICECHARTING_API_TOKEN=
# eBay Marketplace Insights (partner access)
EBAY_APP_ID=

# --- Feed 3: recognition -----------------------------------------------------
# 'mock' (default) | 'ximilar' | 'ocr'
RECOGNIZE_MODE=mock
XIMILAR_API_TOKEN=
