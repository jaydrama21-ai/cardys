{
  "name": "ripreport-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "RipReport data/pricing/catalog/recognition service — implements the RipDataService seam.",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc -p tsconfig.json && cp src/schema.sql dist/schema.sql",
    "ingest:catalog": "tsx src/jobs/ingestCatalog.ts",
    "refresh:prices": "tsx src/jobs/refreshPrices.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.20.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "pg": "^8.22.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
